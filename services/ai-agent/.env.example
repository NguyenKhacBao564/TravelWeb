# AI Agent Service Configuration
# Copy to .env and fill in your values

# Gemini API Key (required for LLM generation and embeddings)
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model for chat generation
GEMINI_MODEL=gemini-2.0-flash

# Gemini embedding model for RAG
GEMINI_EMBEDDING_MODEL=text-embedding-004

# Express backend URL (for tool calls: search_tours, get_tour_detail)
EXPRESS_API_URL=http://localhost:3001

# Internal service token for agent → backend tool calls
# Must match INTERNAL_SERVICE_TOKEN in backend/.env
INTERNAL_SERVICE_TOKEN=your_secure_token_here

# Vector index path (FAISS indexes)
VECTOR_INDEX_PATH=./indexes/faiss

# Vector backend: faiss (default) or qdrant (future)
VECTOR_BACKEND=faiss

# Retrieval score threshold (cosine similarity on normalized vectors)
RETRIEVAL_SCORE_THRESHOLD=0.72

# Logging
LOG_LEVEL=INFO

# Enable debug trace endpoint (POST /agent/trace) - DISABLE in production
ENABLE_DEBUG_TRACE=false

# Session TTL in seconds (default 24h)
SESSION_TTL_SECONDS=86400

# Redis URL for distributed session storage (Phase 8+, optional)
# REDIS_URL=redis://localhost:6379
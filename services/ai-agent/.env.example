# AI Agent Service Configuration
# Copy to .env and fill in your values.

# Gemini API key (used by google_genAI.py for natural language generation)
# NOTE: The legacy module reads GOOGLE_API_KEY.
# Prefer GEMINI_API_KEY for future compatibility with google-genai >= 0.8.
GOOGLE_API_KEY=
GEMINI_API_KEY=

# Gemini model for chat generation
GEMINI_MODEL=gemini-2.0-flash

# Tour data file (local JSON sample used by tour search fallback)
TOUR_DATA_FILE=data/tours_sample.json

# Express backend URL (used for internal tool calls in Phase 1B+)
EXPRESS_API_URL=http://localhost:3001

# Internal service token — must match INTERNAL_SERVICE_TOKEN in backend/.env
# Used by Python client to call Express /internal/tools endpoints.
INTERNAL_SERVICE_TOKEN=

# Timeout for Express internal tool calls in seconds
INTERNAL_TOOL_TIMEOUT_SECONDS=5

# Logging
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Agent Router Mode (Phase 2C)
# ---------------------------------------------------------------------------
# Controls which router the agent uses for tool selection.
# Allowed values:
#   deterministic  — rule-based keyword/pattern matching (default, no API key needed)
#   gemini         — Gemini structured JSON output for tool selection
#   hybrid         — deterministic for obvious cases, Gemini for ambiguous queries
#
# gemini and hybrid require GEMINI_API_KEY (or GOOGLE_API_KEY) to be configured.
# GEMINI_ROUTER_MODEL and GEMINI_ROUTER_TIMEOUT_SECONDS control the routing call.
AGENT_ROUTER_MODE=deterministic

# Gemini model used only for structured routing decisions (not for final answer generation)
GEMINI_ROUTER_MODEL=gemini-2.0-flash

# Timeout for Gemini routing call in seconds (Phase 2C)
GEMINI_ROUTER_TIMEOUT_SECONDS=8

# ---------------------------------------------------------------------------
# Session Memory (Phase 3A)
# ---------------------------------------------------------------------------
# In-process TTL session store for multi-turn travel query context.
# No Redis, no database — lightweight Python dict with background cleanup thread.

# Session TTL in seconds (default 24 hours)
SESSION_TTL_SECONDS=86400

# Maximum recent turns stored per session (default 10)
SESSION_MAX_TURNS=10

# Debug: store raw query text length in turn metadata (default false)
# WARNING: Do not enable in production — only for development debugging
DEBUG_MEMORY_STORE_TEXT=false

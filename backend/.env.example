# Python AI Chatbot Integration
# URL of the FastAPI chatbot service (default: local development)
PYTHON_CHATBOT_URL=http://localhost:8000/chat

# HTTP timeout for chatbot requests in milliseconds
PYTHON_CHATBOT_TIMEOUT_MS=15000

# Chat Analytics Logging (Phase 3A)
# Enable JSONL-based chat analytics (no MSSQL dependency)
CHAT_ANALYTICS_ENABLED=true
# Log file path relative to backend/ directory
CHAT_ANALYTICS_LOG_PATH=logs/chat_analytics.jsonl

# MSSQL Database Configuration
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_SERVER=your_db_server
DB_PORT=1433
DB_DATABASE=your_database_name

# JWT
ACCESS_TOKEN_SECRECT=your_jwt_secret_here

# Server
PORT=3001

# Payment gateways (MoMo / VNPay)
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_PARTNER_CODE=your_partner_code
MOMO_ACCESS_KEY=your_access_key
MOMO_SECRET_KEY=your_secret_key
MOMO_REDIRECT_URL=http://localhost:3000/payment/result
MOMO_IPN_URL=http://localhost:3001/api/payment/momo/ipn

VNPAY_URL=https://sandbox.vnpayment.vn/apis/vnpay
VNPAY_TMN_CODE=your_tmn_code
VNPAY_HASH_SECRET=your_hash_secret
VNPAY_RETURN_URL=http://localhost:3000/payment/result
VNPAY_IPN_URL=http://localhost:3001/api/payment/vnpay/ipn

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Email (Nodemailer)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=your_email@example.com
EMAIL_PASS=your_email_password

# Docker Compose Environment Variables
# Copy to .env for local docker compose

# Frontend
REACT_APP_API_URL=http://localhost:3001

# Backend (Express)
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_SERVER=host.docker.internal  # or your MSSQL host
DB_PORT=1433
DB_DATABASE=your_database_name
ACCESS_TOKEN_SECRECT=your_jwt_secret_here
PORT=3001
CHAT_ANALYTICS_ENABLED=true
CHAT_ANALYTICS_LOG_PATH=logs/chat_analytics.jsonl
PYTHON_CHATBOT_URL=http://ai-agent:8000/chat
PYTHON_CHATBOT_TIMEOUT_MS=15000
INTERNAL_SERVICE_TOKEN=your_secure_token_here
CORS_ORIGINS=http://localhost:3000,http://frontend:80

# AI Agent (FastAPI)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004
EXPRESS_API_URL=http://backend:3001
VECTOR_INDEX_PATH=/app/indexes/faiss
VECTOR_BACKEND=faiss
RETRIEVAL_SCORE_THRESHOLD=0.72
LOG_LEVEL=INFO
ENABLE_DEBUG_TRACE=false
SESSION_TTL_SECONDS=86400

# Payment gateways (optional for local demo)
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_PARTNER_CODE=your_partner_code
MOMO_ACCESS_KEY=your_access_key
MOMO_SECRET_KEY=your_secret_key
MOMO_REDIRECT_URL=http://localhost:3000/payment/result
MOMO_IPN_URL=http://localhost:3001/api/payment/momo/ipn

VNPAY_URL=https://sandbox.vnpayment.vn/apis/vnpay
VNPAY_TMN_CODE=your_tmn_code
VNPAY_HASH_SECRET=your_hash_secret
VNPAY_RETURN_URL=http://localhost:3000/payment/result
VNPAY_IPN_URL=http://localhost:3001/api/payment/vnpay/ipn

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Email (Nodemailer)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=your_email@example.com
EMAIL_PASS=your_email_password